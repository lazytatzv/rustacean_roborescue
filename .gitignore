# --- Rust (PC & STM32) ---
target/
**/*.rs.bk
# Note: Cargo.lock IS committed for reproducible builds (binary project, not library)
# But per-package Cargo.lock (created by colcon) should be ignored
main_ws/src/**/Cargo.lock

# --- ROS 2 (colcon) ---
install/
build/
log/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class

# --- STM32 / Embedded ---
*.bin
*.elf
*.hex

# --- OS / IDE ---
.DS_Store
.vscode/
.idea/
.envrc
.direnv/
# pixi environments
.pixi/*
!.pixi/config.toml


*.png

# --- Security / Certificates (Zenoh QUIC) ---
# 秘密鍵・中間ファイルはコミットしない
**/*.key
**/*.csr
**/*.srl
# server.crt (公開側) は just gen-cert で生成後コミットする → scp不要
# **/*.crt はignoreしない
