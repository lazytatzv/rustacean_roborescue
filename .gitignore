# --- Rust (PC & STM32) ---
target/
**/*.rs.bk
# Note: Cargo.lock IS committed for reproducible builds (binary project, not library)
# But per-package Cargo.lock (created by colcon) should be ignored
main_ws/src/**/Cargo.lock

# --- ROS 2 (colcon) ---
install/
build/
log/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class

# --- STM32 / Embedded ---
*.bin
*.elf
*.hex

# --- OS / IDE ---
.DS_Store
.vscode/
.idea/
.envrc
.direnv/
# pixi environments
.pixi/*
!.pixi/config.toml
