{
  // Operator typically only needs to connect to the robot's zenohd.
  // Use "client" to avoid accepting incoming Zenoh connections on the operator.
  // Change to "peer" only if you want the operator to be a full peer (listen/route).

  // Routerを使った方が安定すると考えるためpeerは使わない
  mode: "client",
  // 主ポート 7447 が使えない場合は 17447 へ自動フォールバック
  connect: { endpoints: ["tcp/10.42.0.1:7447", "tcp/10.42.0.1:17447"] }, // Robot IP (change as needed)
  scouting: { multicast: { enabled: false } },
  transport: { shared_memory: { enabled: true } }
}
