{
  // Peer mode lets operator-side ROS nodes boot even if robot zenohd is temporarily down.
  // It will still try to connect to configured robot endpoint.
  mode: "peer",
  // TCP優先の単一運用（接続安定性重視）
  // operator から robot へ接続する用途のため localhost は含めない。
  connect: {
    endpoints: [
      "tcp/10.42.0.1:7447"
    ]
  }, // Robot IP (change as needed)
  scouting: { multicast: { enabled: false } },
  transport: { shared_memory: { enabled: true } }
}
