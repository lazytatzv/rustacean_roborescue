<robot name="sekirei">
    <link name="base_link">
        <inertial>
            <mass value="0.01"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>
    <link name="arm_base_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/r_a_2019_2020_asm1.STL"/>
            </geometry>
            <origin xyz="-0.08 -0.081 0" rpy="1.57 0 0"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <inertial>
            <mass value="0.01"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>
    <joint name="arm_base_link_joint" type="fixed">
        <origin xyz="0.2 0 0.1" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="arm_base_link"/>
    </joint>
    <link name="arm1_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/r_a_2019_2020_asm2.STL"/>
            </geometry>
            <origin xyz="0 0 0.004" rpy="1.57 0 0"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <inertial>
            <mass value="0.01"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>
    <joint name="arm_joint1" type="revolute">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <parent link="arm_base_link"/>
        <child link="arm1_link"/>
        <limit effort="5" lower="-3.14" upper="3.14" velocity="1.571"/>
    </joint>
    <link name="arm2_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/r_a_2019_2020_asm3.STL"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <inertial>
            <mass value="0.01"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>
    <joint name="arm_joint2" type="revolute">
        <origin xyz="0 -0.048 0.078" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <parent link="arm1_link"/>
        <child link="arm2_link"/>
        <limit effort="5" lower="-3.14" upper="0" velocity="1.571"/>
    </joint>
    <link name="arm3_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/r_a_2019_2020_asm4.STL"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <inertial>
            <mass value="0.01"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>
    <joint name="arm_joint3" type="revolute">
        <origin xyz="0.45 0.007 0.084" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <parent link="arm2_link"/>
        <child link="arm3_link"/>
        <limit effort="5" lower="0" upper="3.14" velocity="1.571"/>
    </joint>
    <link name="arm4_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/r_a_2019_2020_asm5.STL"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 3.14 0"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <inertial>
            <mass value="0.01"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>
    <joint name="arm_joint4" type="revolute">
        <origin xyz="-0.5 0.012 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <parent link="arm3_link"/>
        <child link="arm4_link"/>
        <limit effort="5" lower="-4.71" upper="0" velocity="1.571"/>
    </joint>
    <link name="arm5_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/r_a_2019_l_asm6.STL"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 3.14 0"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <inertial>
            <mass value="0.01"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>
    <joint name="arm_joint5" type="revolute">
        <origin xyz="0.06525 0.028 0.029647" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <parent link="arm4_link"/>
        <child link="arm5_link"/>
        <limit effort="5" lower="-1.57" upper="1.57" velocity="1.571"/>
    </joint>
    <link name="arm6_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/r_a_2019_l_asm7_ver2.STL"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 3.14 0"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <inertial>
            <mass value="0.01"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>
    <joint name="arm_joint6" type="revolute">
        <origin xyz="0.07425 0 -0.03" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <parent link="arm5_link"/>
        <child link="arm6_link"/>
        <limit effort="5" lower="-3.14" upper="3.14" velocity="1.571"/>
    </joint>
    <!-- Gripper (parallel link, 2x Dynamixel) -->
    <link name="gripper_left_link">
        <inertial>
            <mass value="0.01"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>
    <link name="gripper_right_link">
        <inertial>
            <mass value="0.01"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>
    <joint name="gripper_joint7" type="revolute">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <parent link="arm6_link"/>
        <child link="gripper_left_link"/>
        <limit effort="5" lower="-1.57" upper="1.57" velocity="1.0"/>
    </joint>
    <joint name="gripper_joint8" type="revolute">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <parent link="arm6_link"/>
        <child link="gripper_right_link"/>
        <limit effort="5" lower="-1.57" upper="1.57" velocity="1.0"/>
    </joint>
    <!-- End effector (tip) -->
    <link name="link_tip">
        <inertial>
            <mass value="0.01"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>
    <joint name="tip_joint" type="fixed">
        <origin xyz="0.066 0 0" rpy="0 0 0"/>
        <parent link="arm6_link"/>
        <child link="link_tip"/>
    </joint>
    <link name="gui_d435_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/d435.STL"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 -1.57"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <inertial>
            <mass value="0.01"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>
    <joint name="gui_d435_joint" type="fixed">
        <origin xyz="0.066 -0.03105 0" rpy="1.57 0 0"/>
        <parent link="arm6_link"/>
        <child link="gui_d435_link"/>
    </joint>
    <link name="gui_t265_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/t265.STL"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 3.14 1.57"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <inertial>
            <mass value="0.01"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
        </inertial>
    </link>
    <joint name="gui_t265_joint" type="fixed">
        <origin xyz="-0.05945 0.02 0.073" rpy="3.14 3.14 0"/>
        <parent link="arm1_link"/>
        <child link="gui_t265_link"/>
    </joint>

    <!-- ================================================================
         ros2_control: dynamixel_hardware_interface
         arm_backend:=ros2_control 起動時のみ controller_manager が参照する。
         direct モードでは無視される。
         dynamixel_model_folder は launch ファイルで実パスに置換される。
         ================================================================ -->
    <ros2_control name="dynamixel_arm" type="system">
        <hardware>
            <plugin>dynamixel_hardware_interface/DynamixelHardware</plugin>
            <param name="port_name">/dev/ttyUSB0</param>
            <param name="baud_rate">1000000</param>
            <!-- launch ファイルが DYNAMIXEL_MODEL_FOLDER_PLACEHOLDER を実パスに置換 -->
            <param name="dynamixel_model_folder">DYNAMIXEL_MODEL_FOLDER_PLACEHOLDER</param>
            <param name="number_of_joints">6</param>
            <param name="number_of_transmissions">6</param>
            <!-- joint_to_transmission_matrix は省略 → デフォルトで単位行列 (1:1 mapping) -->
        </hardware>

        <!-- ジョイントとGPIOは同順 (identity matrix前提): joint_N ↔ ID 20+N -->
        <joint name="arm_joint1">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="arm_joint2">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="arm_joint3">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="arm_joint4">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="arm_joint5">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>
        <joint name="arm_joint6">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <!-- Dynamixel モーター (ID 21-26): joint と同順 -->
        <gpio name="dxl_21">
            <param name="type">dxl</param>
            <param name="ID">21</param>
            <command_interface name="Goal Position"/>
            <state_interface name="Present Position"/>
            <state_interface name="Present Velocity"/>
            <state_interface name="Present Current"/>
        </gpio>
        <gpio name="dxl_22">
            <param name="type">dxl</param>
            <param name="ID">22</param>
            <command_interface name="Goal Position"/>
            <state_interface name="Present Position"/>
            <state_interface name="Present Velocity"/>
            <state_interface name="Present Current"/>
        </gpio>
        <gpio name="dxl_23">
            <param name="type">dxl</param>
            <param name="ID">23</param>
            <command_interface name="Goal Position"/>
            <state_interface name="Present Position"/>
            <state_interface name="Present Velocity"/>
            <state_interface name="Present Current"/>
        </gpio>
        <gpio name="dxl_24">
            <param name="type">dxl</param>
            <param name="ID">24</param>
            <command_interface name="Goal Position"/>
            <state_interface name="Present Position"/>
            <state_interface name="Present Velocity"/>
            <state_interface name="Present Current"/>
        </gpio>
        <gpio name="dxl_25">
            <param name="type">dxl</param>
            <param name="ID">25</param>
            <command_interface name="Goal Position"/>
            <state_interface name="Present Position"/>
            <state_interface name="Present Velocity"/>
            <state_interface name="Present Current"/>
        </gpio>
        <gpio name="dxl_26">
            <param name="type">dxl</param>
            <param name="ID">26</param>
            <command_interface name="Goal Position"/>
            <state_interface name="Present Position"/>
            <state_interface name="Present Velocity"/>
            <state_interface name="Present Current"/>
        </gpio>
    </ros2_control>
</robot>
