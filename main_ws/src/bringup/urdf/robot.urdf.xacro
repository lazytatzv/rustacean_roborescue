      <topic>arm_joint3/cmd_pos</topic>
      <p_gain>150</p_gain><i_gain>5</i_gain><d_gain>30</d_gain>
      <cmd_max>80</cmd_max><cmd_min>-80</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>arm_joint4</joint_name>
      <topic>arm_joint4/cmd_pos</topic>
      <p_gain>100</p_gain><i_gain>2</i_gain><d_gain>20</d_gain>
