<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="sekirei">

    <!-- Base link with inertial -->
    <xacro:arg name="use_real_hw" default="false"/>
    
    <link name="base_footprint"/>
    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.062" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
        <visual>
            <geometry><box size="0.60 0.35 0.15"/></geometry>
            <material name="silver"><color rgba="0.7 0.7 0.7 1"/></material>
        </visual>
        <collision><geometry><box size="0.60 0.35 0.15"/></geometry></collision>
        <inertial>
            <mass value="1.0"/><origin xyz="0 0 0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
        </inertial>
    </link>

    <!-- Flippers (Mounting bottom-edge) -->
    <xacro:macro name="flipper" params="name x_offset y_offset flip_rpy">
        <link name="${name}">
            <visual>
                <origin xyz="0 0 0" rpy="${flip_rpy}"/>
                <geometry><mesh filename="package://bringup/meshes/flipper.STL"/></geometry>
                <material name="white"><color rgba="1 1 1 1"/></material>
            </visual>
        </link>
        <joint name="${name}_joint" type="revolute">
            <origin xyz="${x_offset} ${y_offset} -0.075" rpy="0 0 0"/>
            <axis xyz="0 1 0"/><parent link="base_link"/><child link="${name}"/>
            <limit effort="5" lower="-3.14" upper="3.14" velocity="1.571"/>
        </joint>
    </xacro:macro>

    <xacro:flipper name="flipper_fl" x_offset="0.3"  y_offset="0.26"   flip_rpy="${-pi/2} 0 ${-pi/2}"/>
    <xacro:flipper name="flipper_fr" x_offset="0.3"  y_offset="-0.26"  flip_rpy="${-pi/2} 0 ${pi/2}"/>
    <xacro:flipper name="flipper_bl" x_offset="-0.3" y_offset="0.26"   flip_rpy="${-pi/2} 0 ${-pi/2}"/>
    <xacro:flipper name="flipper_br" x_offset="-0.3" y_offset="-0.26"  flip_rpy="${-pi/2} 0 ${pi/2}"/>

    <!-- ======================================================================= -->
    <!--  ARM SECTION: LITERALLY COPIED FROM YOUR PROVEN SOURCE (DO NOT CHANGE) -->
    <!-- ======================================================================= -->

    <!-- Arm Base Link -->
    <link name="arm_base_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/r_a_2019_2020_asm1.STL"/>
            </geometry>
            <origin xyz="-0.08 -0.081 0" rpy="1.57 0 0"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.1" radius="0.05"/>
            </geometry>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <origin xyz="0 0 0.05"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
        </inertial>
    </link>

    <joint name="arm_base_link_joint" type="fixed">
        <origin xyz="0.2 0 0.1" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="arm_base_link"/>
    </joint>

    <!-- Arm Link 1 -->
    <link name="arm1_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/r_a_2019_2020_asm2.STL"/>
            </geometry>
            <origin xyz="0 0 0.004" rpy="1.57 0 0"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.08" radius="0.04"/>
            </geometry>
            <origin xyz="0 0 0.04" rpy="0 0 0"/>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <origin xyz="0 0 0.04"/>
            <inertia ixx="0.0008" ixy="0.0" ixz="0.0" iyy="0.0008" iyz="0.0" izz="0.0002"/>
        </inertial>
    </link>

    <joint name="arm_joint1" type="revolute">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <parent link="arm_base_link"/>
        <child link="arm1_link"/>
        <limit effort="5" lower="-3.14" upper="3.14" velocity="1.571"/>
    </joint>

    <!-- Arm Link 2 -->
    <link name="arm2_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/r_a_2019_2020_asm3.STL"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.45 0.08 0.08"/>
            </geometry>
            <origin xyz="0.225 0 0" rpy="0 0 0"/>
        </collision>
        <inertial>
            <mass value="0.6"/>
            <origin xyz="0.225 0 0"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.010" iyz="0.0" izz="0.010"/>
        </inertial>
    </link>

    <joint name="arm_joint2" type="revolute">
        <origin xyz="0 -0.048 0.078" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <parent link="arm1_link"/>
        <child link="arm2_link"/>
        <limit effort="5" lower="-3.14" upper="3.14" velocity="1.571"/>
    </joint>

    <!-- Arm Link 3 -->
    <link name="arm3_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/r_a_2019_2020_asm4.STL"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.5 0.08 0.08"/>
            </geometry>
            <origin xyz="-0.25 0 0" rpy="0 0 0"/>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <origin xyz="-0.25 0 0"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.010" iyz="0.0" izz="0.010"/>
        </inertial>
    </link>

    <joint name="arm_joint3" type="revolute">
        <origin xyz="0.45 0.007 0.084" rpy="0 0 0"/><axis xyz="0 -1 0"/>
        <parent link="arm2_link"/><child link="arm3_link"/>
        <limit effort="5" lower="-3.14" upper="3.14" velocity="1.571"/>
    </joint>

    <!-- Arm Link 4 -->
    <link name="arm4_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/r_a_2019_2020_asm5.STL"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 3.14 0"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.08" radius="0.03"/>
            </geometry>
            <origin xyz="0 0 0.04" rpy="0 0 0"/>
        </collision>
        <inertial>
            <mass value="0.2"/>
            <origin xyz="0 0 0.04"/>
            <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

    <joint name="arm_joint4" type="revolute">
        <origin xyz="-0.5 0.012 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <parent link="arm3_link"/>
        <child link="arm4_link"/>
        <limit effort="5" lower="-3.14" upper="3.14" velocity="1.571"/>
    </joint>

    <!-- Arm Link 5 -->
    <link name="arm5_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/r_a_2019_l_asm6.STL"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 3.14 0"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.06" radius="0.025"/>
            </geometry>
            <origin xyz="0 0 0.03" rpy="0 0 0"/>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <origin xyz="0 0 0.03"/>
            <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

    <joint name="arm_joint5" type="revolute">
        <origin xyz="0.06525 0.028 0.029647" rpy="0 0 0"/><axis xyz="0 0 1"/>
        <parent link="arm4_link"/><child link="arm5_link"/>
        <limit effort="5" lower="-1.57" upper="1.57" velocity="1.571"/>
    </joint>

    <!-- Arm Link 6 -->
    <link name="arm6_link">
        <visual>
            <geometry>
                <mesh filename="package://bringup/meshes/r_a_2019_l_asm7_ver2.STL"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 3.14 0"/>
            <material name="white">
                <color rgba="1 1 1 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder length="0.05" radius="0.02"/>
            </geometry>
            <origin xyz="0 0 0.025" rpy="0 0 0"/>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <origin xyz="0 0 0.025"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

    <joint name="arm_joint6" type="revolute">
        <origin xyz="0.07425 0 -0.03" rpy="0 0 0"/><axis xyz="1 0 0"/>
        <parent link="arm5_link"/><child link="arm6_link"/>
        <limit effort="5" lower="-3.14" upper="3.14" velocity="1.571"/>
    </joint>

    <!-- ======================================================================= -->

    <link name="gripper_left_link"/><link name="gripper_right_link"/>
    <joint name="gripper_joint7" type="revolute"><parent link="arm6_link"/><child link="gripper_left_link"/><origin xyz="0 0 0"/><axis xyz="0 1 0"/><limit lower="-1.57" upper="1.57" effort="5" velocity="1.0"/></joint>
    <joint name="gripper_joint8" type="revolute"><parent link="arm6_link"/><child link="gripper_right_link"/><origin xyz="0 0 0"/><axis xyz="0 1 0"/><limit lower="-1.57" upper="1.57" effort="5" velocity="1.0"/></joint>

    <link name="velodyne"><visual><geometry><cylinder radius="0.05" length="0.07"/></geometry><material name="silver"/></visual></link>
    <joint name="velodyne_joint" type="fixed"><parent link="base_link"/><child link="velodyne"/><origin xyz="0 0 0"/></joint>
    
    <link name="imu_link"/>
    <joint name="imu_joint" type="fixed"><parent link="base_link"/><child link="imu_link"/><origin xyz="0 0 0" rpy="0 0 0"/></joint>

    <xacro:macro name="sim_wheel" params="name y_offset">
        <link name="${name}"><visual><origin rpy="${pi/2} 0 0"/><geometry><cylinder radius="0.062" length="0.05"/></geometry></visual></link>
        <joint name="${name}_joint" type="continuous"><parent link="base_link"/><child link="${name}"/><origin xyz="0 ${y_offset} -0.075"/><axis xyz="0 1 0"/></joint>
    </xacro:macro>
    <xacro:sim_wheel name="left_wheel"  y_offset="0.2"/>
    <xacro:sim_wheel name="right_wheel" y_offset="-0.2"/>

    <ros2_control name="sekirei_dynamixel_hw" type="system">
        <hardware>
            <xacro:if value="$(arg use_real_hw)">
                <plugin>dynamixel_hardware_interface/DynamixelHardware</plugin>
                <param name="port_name">/dev/dynamixel_arm</param>
                <param name="baud_rate">1000000</param>
            </xacro:if>
            <xacro:unless value="$(arg use_real_hw)">
                <plugin>mock_components/GenericSystem</plugin>
            </xacro:unless>
        </hardware>
        <joint name="arm_joint1"><command_interface name="position"/><state_interface name="position"/></joint>
        <joint name="arm_joint2"><command_interface name="position"/><state_interface name="position"/></joint>
        <joint name="arm_joint3"><command_interface name="position"/><state_interface name="position"/></joint>
        <joint name="arm_joint4"><command_interface name="position"/><state_interface name="position"/></joint>
        <joint name="arm_joint5"><command_interface name="position"/><state_interface name="position"/></joint>
        <joint name="arm_joint6"><command_interface name="position"/><state_interface name="position"/></joint>
    </ros2_control>
</robot>
