// ロボット側 ROS2 ノード用 Zenoh セッション設定 (高可用単一構成)
// QUICを最優先し、接続不能時はTCPへ自動フォールバックする。
{
  mode: "client",
  connect: {
    endpoints: [
      "quic/127.0.0.1:7447",
      "tcp/127.0.0.1:7447",
      "quic/127.0.0.1:17447",
      "tcp/127.0.0.1:17447"
    ]
  },
  scouting: {
    multicast: { enabled: false }
  },
  transport: {
    shared_memory: { enabled: true }
  }
}
