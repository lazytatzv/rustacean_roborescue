{
  mode: "peer",
  connect: {
    endpoints: [
      "quic/127.0.0.1:7447",
      "udp/127.0.0.1:7447", "tcp/127.0.0.1:7447",
      "tcp/127.0.0.1:17447"
    ]
  },
  scouting: {
    multicast: { enabled: false }
  },
  transport: {
    shared_memory: { enabled: true },
    link: {
      tls: {
        root_ca_certificate: "quic/server.crt"
      }
    }
  }
}
