// オペレーター側 Zenoh セッション設定 (foxglove_bridge / joy_node 等で使用)
//
// 使い方:
//   export ZENOH_SESSION_CONFIG_URI=file:///path/to/zenoh_operator.json5
//
// 事前にロボットから証明書を取得する (初回のみ):
//   scp robot@ROBOT_IP:~/ros2_ws/install/bringup/share/bringup/config/quic/server.crt ./quic/server.crt
//
// ROBOT_IP を実際のロボットの IP アドレスに書き換えること。
{
  mode: "client",
  connect: {
    endpoints: [
      "quic/ROBOT_IP:7447"
    ]
  },
  scouting: {
    multicast: { enabled: false }
  },
  transport: {
    link: {
      tls: {
        root_ca_certificate: "quic/server.crt"
      }
    }
  }
}
