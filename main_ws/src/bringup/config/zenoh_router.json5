// zenohd ルーター設定 (ロボット実機側)
// network.launch.py から --config で渡される
{
  mode: "router",
  listen: {
    endpoints: ["tcp/0.0.0.0:7447"]         // TLS不要の TCP 接続を待受
  },
  scouting: {
    multicast: { enabled: false }            // Wi-Fi へのマルチキャスト漏れ防止
  },
  transport: {
    shared_memory: { enabled: true }         // 同一マシン内ノード間で SHM 転送
  }
}
