// zenohd ルーター設定 (高可用単一構成)
// QUICを最優先しつつ、同一ポートでTCPも待ち受ける。
{
  mode: "router",
  listen: {
    endpoints: ["quic/0.0.0.0:7447", "tcp/0.0.0.0:7447"]
  },
  scouting: {
    multicast: { enabled: false }
  },
  transport: {
    shared_memory: { enabled: true },
    link: {
      // 圧縮画像など高帯域トピックのバースト送信でTXキューが詰まり
      // "Unable to push non droppable message" でトランスポートが切断される問題を防ぐ。
      // デフォルト: data=4, data_low=4 → 画像ストリーム向けに拡大。
      tx: {
        queue: {
          size: {
            data_high: 16,
            data: 64,
            data_low: 32,
            background: 16
          }
        }
      },
      tls: {
        listen_private_key: "quic/server.key",
        listen_certificate: "quic/server.crt"
      }
    }
  }
}
