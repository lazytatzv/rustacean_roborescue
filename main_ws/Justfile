set shell := ["bash", "-c"]

# 環境変数
export COLCON_ROS_SKIP_INSTALL_CHECK := "1"

# Nix環境下ではgccのcollect2が "Argument list too long" で死ぬので clang+mold を使う
export CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER := "clang"
export CARGO_BUILD_RUSTFLAGS := "-C link-arg=-fuse-ld=mold"

# Nix環境でのパス見失い対策 (絶対パスで固定)
install_dir := shell("pwd") + "/install"
py_path := install_dir + "/lib/python3.12/site-packages"
gen_cmake := install_dir + "/share/rosidl_generator_rs/cmake"
sccache_conf := shell("pwd") + "/.sccache.toml"

# configs
distro := "jazzy"
# CMakeにジェネレーターの場所を強制指定
common_args := "--merge-install --symlink-install --cmake-args -DROSIDL_GENERATOR_RUST=ON -Drosidl_generator_rs_DIR=" + gen_cmake + " -G Ninja"

# ignore
# スペース区切りで追加
ignore_list := "dynamixel_hardware_interface"
ignore_args := if ignore_list != "" { "--packages-ignore " + ignore_list } else { "" }

# nix特有のwarnフィルター
filter := "2>&1 | grep -v 'doesn.t contain any .local_setup... files' || true"


default: forge

# sccache 設定が古い形式(size="20G")のとき自動修復する
sccache-heal:
	if command -v sccache >/dev/null 2>&1; then \
		mkdir -p "${XDG_CACHE_HOME:-$HOME/.cache}/sccache" "$HOME/.config/sccache"; \
		printf '%s\n' '[cache.disk]' "dir = \"${XDG_CACHE_HOME:-$HOME/.cache}/sccache\"" 'size = 21474836480' > "$HOME/.config/sccache/config"; \
		printf '%s\n' '[cache.disk]' "dir = \"${XDG_CACHE_HOME:-$HOME/.cache}/sccache\"" 'size = 21474836480' > "{{sccache_conf}}"; \
		SCCACHE_CONF="{{sccache_conf}}" sccache --stop-server >/dev/null 2>&1 || true; \
		SCCACHE_CONF="{{sccache_conf}}" sccache --start-server >/dev/null 2>&1 || true; \
	fi

clean:
	@echo "Clean..."
	rm -rf build/ install/ log/

# ジェネレーター単体を先にビルド
forge-bindings:
	colcon build --packages-up-to rosidl_generator_rs --merge-install --symlink-install --cmake-args -G Ninja {{filter}}

# 依存パスを強制エクスポートした状態で全体をビルド
forge: sccache-heal forge-bindings
	export AMENT_PREFIX_PATH="{{install_dir}}:$AMENT_PREFIX_PATH"; \
	export PYTHONPATH="{{py_path}}:$PYTHONPATH"; \
	export PATH="{{install_dir}}/lib/rosidl_generator_rs:$PATH"; \
	if [ "${FORGE_USE_SCCACHE:-0}" = "1" ] && command -v sccache >/dev/null 2>&1; then \
		export SCCACHE_CONF="{{sccache_conf}}"; \
		export RUSTC_WRAPPER=sccache; \
		export CARGO_BUILD_RUSTC_WRAPPER=sccache; \
	else \
		echo "[forge] INFO: building without sccache (set FORGE_USE_SCCACHE=1 to enable)."; \
		unset RUSTC_WRAPPER; \
		unset CARGO_BUILD_RUSTC_WRAPPER; \
		unset RUSTC_WORKSPACE_WRAPPER; \
		unset SCCACHE_CONF; \
		unset SCCACHE_CACHE_SIZE; \
	fi; \
	colcon build {{common_args}} {{ignore_args}} {{filter}}

reforge: clean forge

launch *launch_args:
	ROOT=$(cd .. && pwd); \
	export ZENOH_ROUTER_CHECK_ATTEMPTS=-1; \
	if command -v python3 >/dev/null 2>&1 && python3 -c 'import ctypes; ctypes.CDLL("libtbb.so.12")' >/dev/null 2>&1; then \
		cd "$ROOT/main_ws" && source install/setup.bash && ros2 launch bringup system.launch.py {{launch_args}}; \
	elif command -v nix >/dev/null 2>&1 && [ -f "$ROOT/flake.nix" ]; then \
		echo "[launch] libtbb.so.12 not found in current shell. Falling back to nix develop."; \
		cd "$ROOT" && nix develop --accept-flake-config --command bash -lc 'cd main_ws && source install/setup.bash && ros2 launch bringup system.launch.py {{launch_args}}'; \
	else \
		echo "[launch] WARN: libtbb.so.12 is missing and nix is unavailable. Launching anyway (KISS fallback will be disabled)."; \
		cd "$ROOT/main_ws" && source install/setup.bash && ros2 launch bringup system.launch.py {{launch_args}}; \
	fi

# ── Code Quality ──

check: fmt-check lint test

fmt-check:
	cargo fmt --all -- --check
	@echo "✅ Rust formatting OK"

fmt:
	cargo fmt --all
	@echo "✅ Rust formatted"

lint:
	source install/setup.bash && cargo clippy --workspace -- -D warnings
	@echo "✅ Clippy OK"

test:
	source install/setup.bash && cargo test --workspace
	@echo "✅ Tests passed"

check-compile:
	source install/setup.bash && cargo check --workspace
	@echo "✅ Compilation OK"

ready:
	@echo "RUN below command"
	@echo "bass . install/setup.bash"

mm:
	mmdc -i topology/system_topology.mmd -o system_topology.png -s 3


# メモ
sim:
	ROOT=$(cd .. && pwd); cd "$ROOT/main_ws" && source install/setup.bash && export LIBGL_ALWAYS_SOFTWARE=1 && export MESA_GL_VERSION_OVERRIDE=3.3 && export MESA_GLSL_VERSION_OVERRIDE=330 && export QT_QPA_PLATFORM=xcb && export GZ_PARTITION=roborescue && export IGN_PARTITION=roborescue && export GZ_IP=127.0.0.1 && export IGN_IP=127.0.0.1 && ros2 launch bringup simulation.launch.py use_slam:=true use_nav2:=false use_gz_gui:=false use_rviz:=true use_sim_time:=true spawn_delay_sec:=15.0

# Deploy Zenoh TLS certificates from install to src for persistence
setup-zenoh-certs:
	mkdir -p src/bringup/config/quic/
	mkdir -p ../operator_ws/quic/
	if [ -f install/share/bringup/config/quic/server.key ]; then \
		cp install/share/bringup/config/quic/server.key src/bringup/config/quic/; \
	fi
	if [ -f install/share/bringup/config/quic/server.crt ]; then \
		cp install/share/bringup/config/quic/server.crt src/bringup/config/quic/; \
		cp install/share/bringup/config/quic/server.crt ../operator_ws/quic/; \
	fi
	@echo "Zenoh certificates deployed to src/ directories."
