graph LR
  %% =============================================
  %% Rustacean RoboRescue — Network & Hardware Topology
  %% =============================================

  classDef device fill:#e3f2fd,stroke:#1565c0,stroke-width:2px;
  classDef proto fill:#fff9c4,stroke:#fbc02d,stroke-width:2px;
  classDef ros_node fill:#fff,stroke:#333,stroke-width:2px;

  %% =============================================
  %% ロボット実機 (Intel NUC)
  %% =============================================
  subgraph Robot["ロボット実機 (Intel NUC)"]
    NUC[Intel NUC<br/>Ubuntu + ROS 2 Jazzy]:::device

    subgraph Sensors["センサ"]
      STM32[STM32F446<br/>BNO055 IMU]:::device
      VLP16[VLP-16 LiDAR]:::device
      USB_CAM[USB Camera<br/>/dev/video0]:::device
      OMRON[Omron 2JCIE-BU01<br/>環境センサ]:::device
    end

    subgraph Actuators["アクチュエータ"]
      ROBOCLAW[Roboclaw<br/>クローラモータ]:::device
      DXL_F[Dynamixel XM<br/>フリッパ ×4]:::device
      DXL_AG[Dynamixel XM<br/>アーム 6軸 + グリッパ]:::device
    end

    subgraph ROS_Nodes["ROS 2 ノード (NUC)"]
      N_gateway[sensor_gateway<br/>Rust]:::ros_node
      N_vlp[velodyne_driver<br/>+ velodyne_pointcloud]:::ros_node
      N_cam[v4l2_camera]:::ros_node
      N_ffmpeg[ffmpeg_to_foxglove_video]:::ros_node
      N_qr[qr_detector_cpp]:::ros_node
      N_crawler[crawler_driver]:::ros_node
      N_flipper[flipper_driver]:::ros_node
      N_spark[spark_fast_lio]:::ros_node
      N_slam[slam_toolbox]:::ros_node
      N_arm[arm_controller<br/>Rust / IK]:::ros_node
      N_arm_drv[arm_driver<br/>Rust]:::ros_node
      N_omron[omron_bridge]:::ros_node
      N_map_exp[robo_map_exporter]:::ros_node
      N_nav2[Nav2 Stack]:::ros_node
      N_joyctrl[joy_controller]:::ros_node
      N_audio_robot[robot_audio_sender<br/>robot_audio_receiver]:::ros_node
      N_fgbridge[foxglove_bridge<br/>WebSocket :8765]:::ros_node
    end

    NUC -- "USB Serial /dev/stm32<br/>115200 bps" --> STM32
    NUC -- "Ethernet 10.42.0.242<br/>UDP :2368" --> VLP16
    NUC -- "USB /dev/video0" --> USB_CAM
    NUC -- "USB Serial<br/>/dev/ttyUSB0" --> OMRON
    NUC -- "USB Serial /dev/roboclaw<br/>38400 bps" --> ROBOCLAW
    NUC -- "USB U2D2<br/>115200 bps" --> DXL_F
    NUC -- "USB U2D2<br/>1000000 bps" --> DXL_AG

    STM32 -.-> N_gateway
    VLP16 -.-> N_vlp
    USB_CAM -.-> N_cam
    OMRON -.-> N_omron
    N_crawler -.-> ROBOCLAW
    N_flipper -.-> DXL_F
    N_arm_drv -.-> DXL_AG

    N_cam -. "/camera/image_raw/ffmpeg" .-> N_ffmpeg
    N_cam -. "/camera/image_raw" .-> N_qr
    N_arm -. "/arm_joint_commands" .-> N_arm_drv
  end

  %% =============================================
  %% 通信ミドルウェア — Zenoh (rmw_zenoh_cpp)
  %% =============================================
  subgraph Network["通信ミドルウェア — Zenoh (rmw_zenoh_cpp)"]
    ZENOH_R{{zenohd ロボット側<br/>QUIC :7447 / SHM<br/>zenoh_router.json5<br/>(mTLS Server Cert)}}:::proto
    ZENOH_O{{zenohd オペレータ側<br/>QUIC connect<br/>zenoh_ope.json5<br/>(mTLS CA Cert)}}:::proto
    ZENOH_R <== "Wi-Fi / Ethernet<br/>QUIC (UDP :7447) mTLS" ==> ZENOH_O
  end

  %% =============================================
  %% オペレータ PC
  %% =============================================
  subgraph Operator["オペレータ PC"]
    OPE_PC[Operator PC<br/>Ubuntu + ROS 2 Jazzy]:::device
    PS4[PS4 Controller]:::device
    N_joy[joy_node]:::ros_node
    N_audio_ope[operator_audio_sender<br/>operator_audio_receiver]:::ros_node
    FOXGLOVE[Foxglove Studio<br/>ws://robot:8765]:::ros_node

    PS4 -- "USB / Bluetooth" --> OPE_PC
    OPE_PC -.-> N_joy
    OPE_PC -.-> N_audio_ope
  end

  %% =============================================
  %% Zenoh トピック経路
  %% =============================================
  NUC --- ZENOH_R
  OPE_PC --- ZENOH_O

  N_joy           -. "/joy" .->                     ZENOH_O
  ZENOH_R         -. "/joy" .->                     N_joyctrl
  N_joyctrl       -. "/crawler_driver<br/>/flipper_driver" .-> N_crawler & N_flipper
  N_joyctrl       -. "/arm_cmd_vel<br/>/arm_joint_cmd_vel" .-> N_arm
  N_joyctrl       -. "/gripper_cmd" .->             N_arm_drv
  N_joyctrl       -. "/emergency_stop" .->          N_crawler & N_flipper & N_arm & N_arm_drv

  N_audio_ope     -. "/operator/audio<br/>(AudioChunk)" .->  ZENOH_O
  ZENOH_R         -. "/operator/audio" .->          N_audio_robot
  N_audio_robot   -. "/robot/audio<br/>(AudioChunk)" .->     ZENOH_R
  ZENOH_O         -. "/robot/audio" .->             N_audio_ope

  %% =============================================
  %% Foxglove Bridge 経由 (WebSocket)
  %% =============================================
  N_ffmpeg        -. "/camera/compressed_video" .-> N_fgbridge
  N_slam          -. "/map" .->                     N_fgbridge
  N_spark         -. "/odom" .->                    N_fgbridge
  N_vlp           -. "/velodyne_points" .->         N_fgbridge
  N_gateway       -. "/imu/data" .->                N_fgbridge
  N_arm_drv       -. "/joint_states<br/>/gripper_status" .-> N_fgbridge

  N_fgbridge      == "WebSocket<br/>ws://robot_ip:8765" ==> FOXGLOVE
