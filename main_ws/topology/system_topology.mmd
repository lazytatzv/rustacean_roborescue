graph LR
  %% =============================================
  %% Rustacean RoboRescue — System Topology
  %% Full Node, Topic, and Hardware Connectivity
  %% =============================================

  classDef node_style fill:#fff,stroke:#333,stroke-width:2px;
  classDef topic_style fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px;
  classDef diag_style fill:#fce4ec,stroke:#c2185b,stroke-width:1px,stroke-dasharray: 5 5;
  classDef tf_style fill:#fff9c4,stroke:#fbc02d,stroke-width:2px;
  classDef hw_style fill:#e3f2fd,stroke:#1565c0,stroke-width:2px;

  %% =============================================
  %% Operator Station
  %% =============================================
  subgraph Operator["Operator Station (PC)"]
    joy[joy_node]:::node_style
    ope_audio_sender[operator_audio_sender]:::node_style
    ope_audio_receiver[operator_audio_receiver]:::node_style
    foxglove[Foxglove Studio]:::node_style
  end

  T_joy{{/joy<br/>sensor_msgs/Joy}}:::topic_style
  T_ope_audio{{/operator/audio<br/>AudioChunk}}:::topic_style
  T_robot_audio{{/robot/audio<br/>AudioChunk}}:::topic_style

  joy --> T_joy
  ope_audio_sender --> T_ope_audio
  T_robot_audio --> ope_audio_receiver

  %% =============================================
  %% Teleop & Control Logic (NUC)
  %% =============================================
  subgraph Control_Logic["Control Logic (NUC)"]
    op[joy_controller]:::node_style
    T_joy --> op
  end

  T_estop{{/emergency_stop<br/>std_msgs/Bool}}:::topic_style
  op --> T_estop

  %% =============================================
  %% Mobility (Drive + Flippers)
  %% =============================================
  subgraph Mobility["Mobility System"]
    crawler[crawler_driver]:::node_style
    flipper[flipper_driver]:::node_style

    T_c_cmd{{/crawler_driver<br/>CrawlerVelocity}}:::topic_style
    T_f_cmd{{/flipper_driver<br/>FlipperVelocity}}:::topic_style
    T_joint{{/joint_states<br/>sensor_msgs/JointState}}:::topic_style

    op --> T_c_cmd --> crawler
    op --> T_f_cmd --> flipper
    flipper --> T_joint

    T_estop --> crawler & flipper

    HW_roboclaw[Roboclaw Controller]:::hw_style
    HW_dxl_f[Dynamixel Flippers x4]:::hw_style
    crawler -- "USB Serial" --> HW_roboclaw
    flipper -- "USB U2D2" --> HW_dxl_f

    %% Diagnostics
    D_crawl_v{{/crawler_driver/diagnostics/*}}:::diag_style
    crawler -.-> D_crawl_v
  end

  %% =============================================
  %% Manipulation (Arm + Gripper)
  %% =============================================
  subgraph Manipulation["Manipulation System"]
    arm_ik[arm_controller]:::node_style
    arm_drv[arm_gripper_driver]:::node_style

    T_a_cmd{{/arm_cmd_vel<br/>Twist}}:::topic_style
    T_a_jvel{{/arm_joint_cmd_vel<br/>JointState}}:::topic_style
    T_a_joint{{/arm_joint_commands<br/>JointState}}:::topic_style
    T_ee_pose{{/arm_ee_pose<br/>PoseStamped}}:::topic_style
    T_g_cmd{{/gripper_cmd<br/>GripperCommand}}:::topic_style
    T_g_status{{/gripper_status<br/>GripperStatus}}:::topic_style

    op --> T_a_cmd --> arm_ik
    op --> T_a_jvel --> arm_ik
    op --> T_g_cmd --> arm_drv
    arm_ik --> T_a_joint --> arm_drv
    arm_ik --> T_ee_pose
    T_joint --> arm_ik
    arm_drv --> T_g_status
    arm_drv --> T_joint
    T_estop --> arm_ik & arm_drv

    HW_dxl_ag[Dynamixel Arm 6DOF + Gripper]:::hw_style
    arm_drv -- "USB U2D2 (1Mbps)" --> HW_dxl_ag

    %% Diagnostics
    D_arm_ik{{/arm_controller/diagnostics/*}}:::diag_style
    arm_ik -.-> D_arm_ik
  end

  %% =============================================
  %% Vision & Perception
  %% =============================================
  subgraph Vision["Vision & QR"]
    v4l2[v4l2_camera]:::node_style
    qr[qr_detector_cpp]:::node_style
    ffmpeg_conv[ffmpeg_to_foxglove_video]:::node_style

    T_cam{{/camera/image_raw<br/>sensor_msgs/Image}}:::topic_style
    T_cam_ffmpeg{{/camera/image_raw/ffmpeg<br/>FFMPEGPacket}}:::topic_style
    T_comp_video{{/camera/compressed_video<br/>foxglove_msgs/CompressedVideo}}:::topic_style
    T_qr{{/camera/qr_codes<br/>std_msgs/String}}:::topic_style

    HW_cam[USB Camera /dev/video0]:::hw_style
    HW_cam --> v4l2 -- "Intra-process" --> qr --> T_qr
    v4l2 --> T_cam_ffmpeg --> ffmpeg_conv --> T_comp_video
  end

  %% =============================================
  %% Audio Bridge
  %% =============================================
  subgraph Audio["Audio Bridge"]
    robot_sender[robot_audio_sender]:::node_style
    robot_receiver[robot_audio_receiver]:::node_style

    HW_mic[Robot Microphone]:::hw_style
    HW_spk[Robot Speaker]:::hw_style
    HW_mic --> robot_sender --> T_robot_audio
    T_ope_audio --> robot_receiver --> HW_spk
  end

  %% =============================================
  %% Localization & SLAM
  %% =============================================
  subgraph SLAM_Loc["Localization & SLAM"]
    gateway[sensor_gateway]:::node_style
    spark_lio[spark_fast_lio]:::node_style
    pc2ls[pointcloud_to_laserscan]:::node_style
    slam[slam_toolbox]:::node_style

    T_imu{{/imu/data<br/>sensor_msgs/Imu}}:::topic_style
    T_imu_h{{/imu/health<br/>std_msgs/Bool}}:::topic_style
    T_raw_pts{{/velodyne_points<br/>sensor_msgs/PointCloud2}}:::topic_style
    T_scan{{/scan<br/>sensor_msgs/LaserScan}}:::topic_style
    T_odom{{/odom<br/>nav_msgs/Odometry}}:::topic_style
    T_map{{/map<br/>nav_msgs/OccupancyGrid}}:::topic_style

    HW_stm32[STM32 + BNO055]:::hw_style
    HW_vlp16[VLP-16 LiDAR]:::hw_style

    HW_stm32 -- "USB Serial" --> gateway --> T_imu & T_imu_h
    T_imu --> spark_lio
    HW_vlp16 -- "Ethernet (UDP)" --> T_raw_pts
    T_raw_pts --> spark_lio & pc2ls
    T_scan --> slam
    pc2ls --> T_scan
    spark_lio --> T_odom
    slam --> T_map
  end

  %% =============================================
  %% Environmental Sensing
  %% =============================================
  subgraph Environmental["Environmental"]
    omron[omron_bridge]:::node_style
    T_omron{{omron/*<br/>std_msgs/Float32}}:::topic_style

    HW_omron[Omron 2JCIE-BU01]:::hw_style
    HW_omron -- "USB Serial" --> omron --> T_omron
    T_odom --> omron
  end

  %% =============================================
  %% TF Tree (Static & Dynamic)
  %% =============================================
  subgraph TF["TF Tree Summary"]
    TF_map_odom["map → odom<br/>(slam_toolbox)"]:::tf_style
    TF_odom_base["odom → base_link<br/>(spark_fast_lio)"]:::tf_style
    TF_base_all["base_link → sensors/links<br/>(robot_state_publisher)"]:::tf_style

    TF_map_odom --- TF_odom_base --- TF_base_all
  end

  %% =============================================
  %% Connectivity to Operator
  %% =============================================
  fgbridge[foxglove_bridge<br/>:8765]:::node_style

  T_comp_video & T_map & T_odom & T_scan & T_joint & T_imu & T_qr & T_omron --> fgbridge
  fgbridge == "WebSocket" ==> foxglove
