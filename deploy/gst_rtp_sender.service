[Unit]
Description=GStreamer RTP Audio Sender (robot)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/tatsv/working/rustacean_roborescue
Environment="DEST_IP=192.168.1.100"
Environment="DEST_PORT=5002"
ExecStart=/usr/bin/env bash /home/tatsv/working/rustacean_roborescue/tools/gst_rtp_sender.sh $DEST_IP $DEST_PORT
Restart=on-failure

[Install]
WantedBy=multi-user.target
