# ============================================================
# udev ルール — ロボットシリアルデバイス
# ============================================================
# インストール:
#   sudo cp 99-robot.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger
#
# デバイス識別情報の確認方法:
#   lsusb                          … idVendor / idProduct 確認
#   udevadm info -a /dev/ttyUSB0  … ATTRS{serial} 確認
#
# 同一 idVendor/idProduct の U2D2 が複数ある場合は ATTRS{serial} で区別する。
# 以下の <SERIAL_FLIPPER> / <SERIAL_ARM> を実機の iSerial 値に書き換えること。
# ============================================================

# Roboclaw モータコントローラ (BasicMicro)
SUBSYSTEM=="tty", ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2404", SYMLINK+="roboclaw", MODE="0666"

# STM32F4 (BNO055 IMU ゲートウェイ)
SUBSYSTEM=="tty", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="5740", SYMLINK+="stm32", MODE="0666"

# ── Dynamixel U2D2 — フリッパ専用バス ───────────────────────────────────────
# アームとフリッパは別バス (別 U2D2) のため、シリアル番号で区別する。
# <SERIAL_FLIPPER> を `udevadm info -a /dev/ttyUSBx | grep serial` の値に変更。
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6014", ATTRS{serial}=="<SERIAL_FLIPPER>", SYMLINK+="dynamixel_flipper", MODE="0666"

# ── Dynamixel U2D2 — アーム + グリッパ共用バス ──────────────────────────────
# アームジョイント (ID 21-26) とグリッパ (ID 10) は同一 RS485 バス上。
# <SERIAL_ARM> を実機の iSerial 値に変更。
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6014", ATTRS{serial}=="<SERIAL_ARM>", SYMLINK+="dynamixel_arm", MODE="0666"
