# ============================================================
# udev ルール — ロボットシリアルデバイス
# ============================================================
# インストール:
#   sudo cp 99-robot.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger
#
# デバイス識別情報の確認方法:
#   lsusb                          … idVendor / idProduct 確認
#   udevadm info -a /dev/ttyUSB0  … ATTRS{serial} 確認
#
# 同一 idVendor/idProduct の U2D2 が複数ある場合は ATTRS{serial} で区別する。
# 以下の <SERIAL_FLIPPER> / <SERIAL_ARM> を実機の iSerial 値に書き換えること。
# ============================================================
#
# デバイスファイルは実行権限関係ない
# とりあえず0666で基本的にフル権限にしている

# 完全に整合性が取れているのは
# cralwer, flipper, arm

# Roboclaw モータコントローラ (BasicMicro)
# roboclawは絶対に一つなのでこれは弄る必要はない
SUBSYSTEM=="tty", ATTRS{idVendor}=="03eb", ATTRS{idProduct}=="2404", SYMLINK+="roboclaw", MODE="0666"

# STM32F4 (BNO055 IMU ゲートウェイ)
# idの確認をする必要性がある
SUBSYSTEM=="tty", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="5740", SYMLINK+="stm32", MODE="0666"

# ── Dynamixel U2D2 — フリッパ専用バス ───────────────────────────────────────
# アームとフリッパは同一 VID/PID のため、iSerial(ID_SERIAL_SHORT) で区別する。
# lsusbでFTDI(0403:6014)が2本見えていても、ここ未設定だと名前固定はできない。
# U2D2を変えた場合iserialも変わることに注意する!!!!!!

# flipperのdynamixelのIDは1,2,3,4
# yamlでid-mapを変えることができる
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6014", ENV{ID_SERIAL_SHORT}=="FT763H1F", SYMLINK+="dynamixel_flipper", MODE="0666"

# ── Dynamixel U2D2 — アーム + グリッパ共用バス ──────────────────────────────
# アームジョイント (ID 21-26) とグリッパ (ID 10) は同一 RS485 バス上。
SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6014", ENV{ID_SERIAL_SHORT}=="FT763IA0", SYMLINK+="dynamixel_arm", MODE="0666"


# ── USB カメラ ────────────────────────────────────────────────────────────────
# ENV{ID_V4L_CAPABILITIES}==":capture:" でメタデータ専用ノードを除外し
# キャプチャノードのみにシンボリックリンクを張る。

# フロントカメラ (KYE/Genius WideCam F100 0458:708c)
# バッテリーの上にある四角いやつ
# 差し替えにより変わる可能性あり
SUBSYSTEM=="video4linux", ATTRS{idVendor}=="0458", ATTRS{idProduct}=="708c", ENV{ID_V4L_CAPABILITIES}==":capture:", KERNELS=="1-3.1", SYMLINK+="camera_front_left", MODE="0666"


SUBSYSTEM=="video4linux", ATTRS{idVendor}=="0458", ATTRS{idProduct}=="708c", ENV{ID_V4L_CAPABILITIES}==":capture:", KERNELS=="1-3.2", SYMLINK+="camera_front_right", MODE="0666"

# アームの先端中カメラ (Buffalo/Melco 0411:02da)
SUBSYSTEM=="video4linux", ATTRS{idVendor}=="0411", ATTRS{idProduct}=="02da", ENV{ID_V4L_CAPABILITIES}==":capture:", SYMLINK+="camera_arm", MODE="0666"

# RealSense 435i カラーストリーム (Intel 8086:0b3a)
# 深度・IRノードも同一 VID/PID で生えるが :capture: でカラーのみを対象とする
# 深度データは librealsense 経由でアクセスすること
# アーム先端の横
SUBSYSTEM=="video4linux", ATTRS{idVendor}=="8086", ATTRS{idProduct}=="0b3a", ENV{ID_V4L_CAPABILITIES}==":capture:", SYMLINK+="camera_realsense", MODE="0666"

# 360 degree camera richo
SUBSYSTEM=="video4linux", ATTRS{idVendor}=="05ca", ATTRS{idProduct}=="2711", ENV{ID_V4L_CAPABILITIES}==":capture:", SYMLINK+="camera_ricoh", MODE="0666"

